        <color rgba="0.3 0.3 0.3 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.08" length="0.15" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.5" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>

  <joint name="lidar_down_joint" type="fixed">
    <origin xyz="-0.3 0 0.6" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar_down_link" />
  </joint>

  <link name="lidar_up_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.08" length="0.15" />
      </geometry>
      <material name="lidar_material">
        <color rgba="0.3 0.3 0.3 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.08" length="0.15" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.5" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>

  <joint name="lidar_up_joint" type="fixed">
    <origin xyz="0 0 1.0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar_up_link" />
  </joint>

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="j1">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="j2">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="j3">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="j4">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="j5">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="j6">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wl1_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wl2_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wr1_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wr2_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ============ GAZEBO SENSOR DEFINITIONS ============ -->
  <!-- Camera sensors - native Gazebo Harmonic (no Classic plugins) -->
  
  <gazebo reference="camera_down_link">
    <sensor name="camera_down" type="camera">
      <update_rate>30.0</update_rate>
      <camera name="camera_down">
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>5.0</far>
        </clip>
      </camera>
      <topic>camera_down</topic>
      <always_on>1</always_on>
    </sensor>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="camera_up_link">
    <sensor name="camera_up" type="camera">
      <update_rate>30.0</update_rate>
      <camera name="camera_up">
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
      <topic>camera_up</topic>
      <always_on>1</always_on>
    </sensor>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="camera_hand_link">
    <sensor name="camera_hand" type="camera">
      <update_rate>30.0</update_rate>
      <camera name="camera_hand">
        <horizontal_fov>1.5708</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>2.0</far>
        </clip>
      </camera>
      <topic>camera_hand</topic>
      <always_on>1</always_on>
    </sensor>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="lidar_down_link">
    <sensor name="lidar_down" type="gpu_lidar">
      <update_rate>10.0</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1.0</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <topic>lidar_down</topic>
      <always_on>1</always_on>
    </sensor>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="lidar_up_link">
    <sensor name="lidar_up" type="gpu_lidar">
      <update_rate>10.0</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1.0</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <topic>lidar_up</topic>
      <always_on>1</always_on>
    </sensor>
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- Gazebo ros2_control plugin -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>/home/zhan/train_robot-main/train_robot/ros2_ws/install/robot_description/share/robot_description/config/gazebo_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
                  "title": "damping = 350 N·s/m"
                },
                {
                  "id": "param-load",
                  "class": "topic",
                  "title": "loading_stiffness = 5000 N/m"
                },
                {
                  "id": "param-unload",
                  "class": "topic",
                  "title": "unloading_stiffness = 1800 N/m"
                },
                {
                  "id": "param-lock",
                  "class": "topic",
                  "title": "lock_stiffness = 18000 N/m"
                },
                {
                  "id": "param-limit",
                  "class": "topic",
                  "title": "max_force = 500 N"
                }
              ]
            }
          },
          {

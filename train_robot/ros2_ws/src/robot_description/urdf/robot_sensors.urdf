<?xml version='1.0' encoding='utf-8'?>
<robot name="robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="camera_down_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
      <material name="camera_material">
        <color rgba="0.5 0.5 0.5 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.1" />
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
  </link>

  <joint name="camera_down_joint" type="fixed">
    <origin xyz="-0.3 0 0.3" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="camera_down_link" />
  </joint>

  <link name="camera_up_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
      <material name="camera_material">
        <color rgba="0.5 0.5 0.5 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.1" />
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
  </link>

  <joint name="camera_up_joint" type="fixed">
    <origin xyz="0 0 0.8" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="camera_up_link" />
  </joint>

  <link name="camera_hand_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.03 0.03" />
      </geometry>
      <material name="camera_material">
        <color rgba="0.5 0.5 0.5 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.03 0.03" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001" />
    </inertial>
  </link>

  <joint name="camera_hand_joint" type="fixed">
    <origin xyz="0 0 0.05" rpy="0 0 0" />
    <parent link="link6" />
    <child link="camera_hand_link" />
  </joint>

  <gazebo reference="camera_down_link">
    <sensor name="camera_down" type="camera">
      <update_rate>60.0</update_rate>
      <camera name="camera_down">
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>5.0</far>
        </clip>
      </camera>
      <plugin name="camera_down_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>60.0</updateRate>
        <cameraName>camera_down</cameraName>
        <imageTopicName>camera_down_rgb</imageTopicName>
        <cameraInfoTopicName>camera_down_info</cameraInfoTopicName>
        <depthImageTopicName>camera_down_dp</depthImageTopicName>
        <depthCameraInfoTopicName>camera_down_dp_info</depthCameraInfoTopicName>
        <frameName>camera_down_link</frameName>
        <hackBaseline>0.07</hackBaseline>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_up_link">
    <sensor name="camera_up" type="camera">
      <update_rate>60.0</update_rate>
      <camera name="camera_up">
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
      <plugin name="camera_up_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>60.0</updateRate>
        <cameraName>camera_up</cameraName>
        <imageTopicName>camera_up_rgb</imageTopicName>
        <cameraInfoTopicName>camera_up_info</cameraInfoTopicName>
        <depthImageTopicName>camera_up_dp</depthImageTopicName>
        <depthCameraInfoTopicName>camera_up_dp_info</depthCameraInfoTopicName>
        <frameName>camera_up_link</frameName>
        <hackBaseline>0.07</hackBaseline>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_hand_link">
    <sensor name="camera_hand" type="camera">
      <update_rate>60.0</update_rate>
      <camera name="camera_hand">
        <horizontal_fov>1.5708</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>2.0</far>
        </clip>
      </camera>
      <plugin name="camera_hand_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>60.0</updateRate>
        <cameraName>camera_hand</cameraName>
        <imageTopicName>camera_hand_rgb</imageTopicName>
        <cameraInfoTopicName>camera_hand_info</cameraInfoTopicName>
        <depthImageTopicName>camera_hand_dp</depthImageTopicName>
        <depthCameraInfoTopicName>camera_hand_dp_info</depthCameraInfoTopicName>
        <frameName>camera_hand_link</frameName>
        <hackBaseline>0.07</hackBaseline>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>

  <link name="lidar_down_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.05" length="0.1" />
      </geometry>
      <material name="lidar_material">
        <color rgba="0.3 0.3 0.3 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.05" length="0.1" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.5" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>

  <joint name="lidar_down_joint" type="fixed">
    <origin xyz="-0.3 0 0.6" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar_down_link" />
  </joint>

  <link name="lidar_up_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.05" length="0.1" />
      </geometry>
      <material name="lidar_material">
        <color rgba="0.3 0.3 0.3 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.05" length="0.1" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.5" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>

  <joint name="lidar_up_joint" type="fixed">
    <origin xyz="0 0 1.0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar_up_link" />
  </joint>

  <gazebo reference="lidar_down_link">
    <sensor name="lidar_down" type="ray">
      <update_rate>10.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1.0</resolution>
            <min_angle>-0.4363</min_angle>
            <max_angle>0.4363</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="lidar_down_controller" filename="libgazebo_ros_ray_sensor.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>10.0</updateRate>
        <topicName>lidar_down</topicName>
        <frameName>lidar_down_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="lidar_up_link">
    <sensor name="lidar_up" type="ray">
      <update_rate>10.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1.0</resolution>
            <min_angle>-0.4363</min_angle>
            <max_angle>0.4363</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="lidar_up_controller" filename="libgazebo_ros_ray_sensor.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>10.0</updateRate>
        <topicName>lidar_up</topicName>
        <frameName>lidar_up_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

</robot>
  </gazebo>
  <gazebo reference="joint_grasp">
    <preserveFixedJoint>true</preserveFixedJoint>
    <sensor name="wrist_ft_sensor" type="force_torque">
      <update_rate>500.0</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <topic>wrist_ft</topic>
      <force_torque>
        <frame>child</frame>
        <measure_direction>child_to_parent</measure_direction>
      </force_torque>
    </sensor>
  </gazebo>
  <gazebo reference="lidar_down_link">
    <sensor name="lidar_down" type="gpu_lidar">
      <update_rate>10.0</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1.0</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <topic>lidar_down</topic>
      <always_on>1</always_on>
    </sensor>
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="lidar_up_link">
    <sensor name="lidar_up" type="gpu_lidar">
      <update_rate>10.0</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1.0</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <topic>lidar_up</topic>
      <always_on>1</always_on>
    </sensor>
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find robot_description)/config/gazebo_controllers.yaml</parameters>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>j1</joint_name>
      <topic>/train_robot/j1_cmd_pos</topic>
      <p_gain>5.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.2</d_gain>
      <cmd_max>50.0</cmd_max>
      <cmd_min>-50.0</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>j2</joint_name>
      <topic>/train_robot/j2_cmd_pos</topic>
      <p_gain>5.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.2</d_gain>
      <cmd_max>50.0</cmd_max>
      <cmd_min>-50.0</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>j3</joint_name>
      <topic>/train_robot/j3_cmd_pos</topic>
      <p_gain>5.0</p_gain>
      <i_gain>0.0</i_gain>

                }
              ]
            }
          },
          {
            "id": "future",
            "class": "topic",
            "title": "10. 后续计划",
            "children": {
              "attached": [
                {
                  "id": "future-calibration",
                  "class": "topic",
                  "title": "标定参数：根据真实车钩缓冲器阻抗曲线拟合 k_load/k_unload/k_lock"
                },
                {
                  "id": "future-geometry",
                  "class": "topic",
                  "title": "改进接触几何：用接触面/轴向距离代替单点欧氏距离"
                },

    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>j4</joint_name>
      <topic>/train_robot/j4_cmd_pos</topic>
      <p_gain>5.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.2</d_gain>
      <cmd_max>50.0</cmd_max>
      <cmd_min>-50.0</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>j5</joint_name>
      <topic>/train_robot/j5_cmd_pos</topic>
      <p_gain>5.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.2</d_gain>
      <cmd_max>50.0</cmd_max>
      <cmd_min>-50.0</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>j6</joint_name>
      <topic>/train_robot/j6_cmd_pos</topic>
      <p_gain>5.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.2</d_gain>
      <cmd_max>50.0</cmd_max>
      <cmd_min>-50.0</cmd_min>
    </plugin>
  </gazebo>
